  # ── Rust acceleration layer (optional) ────────────────────────────────────────
> RUST_AVAILABLE = False
  
> try:
>     from lumen._lumen_rust import LumenDictRust, LumenDictFullRust  # type: ignore
>     from lumen._lumen_rust import decode_binary_records_rust as _decode_binary_records_rust  # type: ignore
  
      # Override the Python decoder with the Rust one transparently
>     def decode_binary_records(data: bytes):  # type: ignore[no-redef]
>         """Decode LUMEN binary data. Uses Rust accelerated decoder when available."""
>         result = _decode_binary_records_rust(data)
          # Rust decoder wraps all decoded items in an outer list.
          # T_LIST path: returns [[item1, item2, ...]] -> unwrap to [item1, item2, ...]
          # T_MATRIX path: returns [{"col": val}, ...] -> already correct
          # T_POOL_DEF + T_LIST: same unwrap needed
>         if (result and isinstance(result, list) and len(result) == 1
>                 and isinstance(result[0], list)):
>             return result[0]
>         return result
  
>     RUST_AVAILABLE = True
> except ImportError:
      # Graceful fallback: expose Python-backed shims with the same interface
>     class LumenDictRust(LumenDict):  # type: ignore[no-redef]
>         """
>         Python shim for LumenDictRust — active when the Rust extension is not built.
>         Build the Rust extension with: ``pip install maturin && maturin develop``
>         """
  
>         def encode_binary_pooled_raw(self) -> bytes:
>             return self.encode_binary_pooled()
  
>         def encode_binary_zlib(self) -> bytes:  # type: ignore[override]
>             return _zlib.compress(self.encode_binary_pooled(), 6)
  
>         def bench_encode_text_only(self, iters: int) -> int:
>             return len(self.encode_text()) * iters
  
>         def bench_encode_binary_only(self, iters: int) -> int:
>             return len(self.encode_binary_pooled()) * iters
  
>         def bench_encode_text_clone(self, iters: int) -> int:
>             return len(self.encode_text()) * iters
  
>         def bench_encode_binary_clone(self, iters: int) -> int:
>             return len(self.encode_binary_pooled()) * iters
  
>         def __repr__(self) -> str:
>             return (
>                 f"LumenDictRust[PythonShim]("
>                 f"records={len(self._data)}, pool={len(self._pool)})"
>             )
  
